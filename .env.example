# Azure OpenAI (Chapter 2, 5, 8)
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Azure Identity
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id

# Azure Resource Group
AZURE_RESOURCE_GROUP=rg-agentic-showcase
AZURE_LOCATION=eastus

# Azure Service Bus (Chapter 6)
AZURE_SERVICEBUS_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=...;SharedAccessKey=...
AZURE_SERVICEBUS_QUEUE_NAME=agent-events

# Azure Event Hubs (Chapter 3, 6)
AZURE_EVENTHUB_CONNECTION_STRING=Endpoint=sb://your-eventhub.servicebus.windows.net/;SharedAccessKeyName=...;SharedAccessKey=...
AZURE_EVENTHUB_NAME=agent-stream

# Azure AI Foundry (Chapter 8)
AZURE_AI_PROJECT_CONNECTION_STRING=your-ai-project-connection-string

# Application Insights (Chapter 8)
APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...
